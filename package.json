{
  "name": "claude-usage",
  "author": {
    "name": "Jonathan Mackay",
    "url": "https://github.com/jjsmackay"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jjsmackay/claude-usage-vscode"
  },
  "displayName": "Claude Usage",
  "description": "Monitor your Claude Code usage and rate limits",
  "version": "0.2.0",
  "publisher": "CleverMonkey",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Visualization"
  ],
  "icon": "resources/claude-color.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "icons": {
      "claude-icon": {
        "description": "Claude Icon",
        "default": {
          "fontPath": "resources/claude.woff",
          "fontCharacter": "\\e900"
        }
      }
    },
    "commands": [
      {
        "command": "claude-usage.noop",
        "title": "Claude Usage: No-op"
      },
      {
        "command": "claude-usage.refresh",
        "title": "Refresh Claude Usage"
      },
      {
        "command": "claude-usage.login",
        "title": "Login to Claude Code"
      }
    ],
    "configuration": {
      "title": "Claude Usage",
      "properties": {
        "claudeUsage.updateInterval": {
          "type": "number",
          "default": 300,
          "description": "Update interval in seconds (default: 300 = 5 minutes)"
        },
        "claudeUsage.showNotifications": {
          "type": "boolean",
          "default": false,
          "description": "Show notifications when usage is high"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "vscode:publish": "vsce publish",
    "compile": "tsc -p ./",
    "vscode:package": "vsce package",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:unit": "npm run compile && mocha out/test/suite/progress-bar.test.js out/test/suite/time-formatter.test.js --ui tdd --color"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.28.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^4.9.3"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "vsce": "^2.15.0"
  }
}
